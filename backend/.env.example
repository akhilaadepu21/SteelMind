# SteelMind AI - Environment Configuration
# Copy this file to .env and fill in your values

# REQUIRED: Groq API key (get from https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# REQUIRED for semantic intent classification: Google Gemini API key
# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OPTIONAL: Neo4j - for knowledge graph features
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=steelguardian

# OPTIONAL: Redis - for production session caching
# REDIS_URL=redis://localhost:6379
